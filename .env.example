# ─── LiveKit ────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Groq (primary LLM — get from console.groq.com) ─────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Gemini (fallback LLM — get from aistudio.google.com) ─────────────
GOOGLE_API_KEY=

# ─── STT / TTS ──────────────────────────────────────────────────────────────
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx
DEEPGRAM_API_KEY=

# ─── Supabase (get from supabase.com → project settings → API) ───────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxx
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project-id.supabase.co:5432/postgres

# ─── Redis Cache (get from Redis Cloud dashboard) ─────────────────────────────
REDIS_HOST=your-redis-host.redislabs.com
REDIS_PORT=12345
REDIS_PASSWORD=your-redis-password
REDIS_USERNAME=default

# ─── User Profile ────────────────────────────────────────────────────────────
JARVIS_USER_NAME=YourName
JARVIS_USER_TIMEZONE=Asia/Kolkata

# ─── MCP Server ──────────────────────────────────────────────────────────────
SERVER_NAME=JARVIS
DEBUG=false
